# Margaret's MemoryCare Music — Environment Variables
# Copy to .env.local and fill in real values before running the app.

# ── Supabase (required) ────────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API

# Public URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Application URL (required in production) ───────────────────────────────────
# Used for email callback links (password reset, etc.)
# In local dev, defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=https://margaretsmemorycaremusic.com

# ── Email delivery via Resend (Sprint 7 — add when DNS is verified) ────────────
# Create at resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Verified sending address (must be on your verified domain in Resend)
EMAIL_FROM_ADDRESS=notifications@margaretsmemorycaremusic.com

# Reply-to for notification emails
EMAIL_REPLY_TO=privacy@margaretsmemorycaremusic.com

# ── Local dev only ─────────────────────────────────────────────────────────────
# Prevents webpack cache failures on OneDrive-synced paths (Windows only)
# NEXT_DISABLE_WEBPACK_CACHE=1
